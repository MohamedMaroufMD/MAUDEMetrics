flowchart TD
    classDef user fill:#4e79a7,stroke:#3d5a80,stroke-width:2px,color:white
    classDef interface fill:#59a14f,stroke:#406c35,stroke-width:2px,color:white
    classDef engine fill:#9c755f,stroke:#7a5c48,stroke-width:2px,color:white
    classDef external fill:#e15759,stroke:#b03b46,stroke-width:2px,color:white
    classDef storage fill:#76b7b2,stroke:#4a7a75,stroke-width:2px,color:black

    User(("User\n(researchers, clinicians,\nquality assurance)")):::user
    WebInterface["Web Interface\n(flask + jinja2 + bootstrap 5)"]:::interface
    SearchEngine["Search Engine\n(brand, product code, manufacturer,\nproduct class, date range)"]:::engine
    openFDA["openFDA API\n(device event endpoint)\n[search_after active pagination]"]:::external
    DataProcessing["Data Processing Engine\n(Chunked Extraction + O(1) Dictionary Lookup)"]:::engine
    SQLite[("SQLite Database\n(4 normalized tables:\nevents, devices, patients, mdr_texts)")]:::storage

    ResultsEngine["Results Engine\n(triggers results display)"]:::engine
    AnalyticsEngine["Analytics Engine\n(statistical analysis)"]:::engine
    ExportEngine["Export Stream Engine\n(openpyxl write_only mode)"]:::engine

    ResultsPage["Results Page\n(recent events)"]:::interface
    AnalyticsDashboard["Analytics Dashboard\n(interactive visualizations,\ndemographics, trends)"]:::interface
    ExportModule["Export Module\n(3 options:\nOptimized, Raw JSON, & Summary Stats)"]:::interface
    DataStorage[("Data Storage\n(System file dump)")]:::storage

    User -- "User query (UI)" --> WebInterface
    WebInterface -- "Search criteria" --> SearchEngine
    SearchEngine -- "API request" --> openFDA
    openFDA -- "Raw JSON streams" --> DataProcessing
    DataProcessing -- "Processed data" --> SQLite

    SQLite -- "Query results" --> ResultsEngine
    SQLite -- "Analytics metrics" --> AnalyticsEngine
    SQLite -- "Memory-safe cursors" --> ExportEngine

    ResultsEngine -- "Formatted tables" --> ResultsPage
    AnalyticsEngine -- "Summary metadata" --> ResultsEngine
    AnalyticsEngine -- "Visualization data" --> AnalyticsDashboard
    AnalyticsEngine -- "Aggregated data" --> ExportEngine
    
    ExportEngine -- "Memory-efficient compilation" --> ExportModule
    ExportModule -- "Streaming save (.xlsx/.csv)" --> DataStorage
    
    DataProcessing -. "Real-time extraction" .-> ResultsPage
    ExportEngine -. "Zero-DOM instant generation" .-> ExportModule
